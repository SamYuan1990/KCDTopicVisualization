"accepted_at":"2021-09-14","additional_categories":[{"category":"case","subcategory":"true"},{"category":"deep","subcategory":"4"},{"category":"audience","subcategory":"混合"},{"category":"diffcult","subcategory":"4"},{"category":"deployment","subcategory":"4"}],"artwork_url":"https://github.com/cncf/artwork/blob/master/examples/sandbox.md#karmada-logos","chat_channel":"#karmada","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","description":"面向运维工程师、架构师和技术管理者。该演讲主要介绍了基于Karmada的多集群管理调度平台实践，属于编排与管理分类。演讲中，Karmada作为核心编排框架，与自研的BRS抽象层和调度系统协同，构建了全球异构资源统一管理平台。","devstats_url":"https://karmada.devstats.cncf.io/","incubating_at":"2023-12-12","latest_annual_review_at":"2022-10-29","latest_annual_review_url":"https://github.com/cncf/toc/pull/954","mailing_list_url":"https://groups.google.com/forum/#!forum/karmada","maturity":"incubating","repositories":[{"url":"https://github.com/karmada-io/karmada","primary":true}],"slack_url":"https://cloud-native.slack.com/messages/karmada","summary":{"business_use_case":"Managing workloads across diverse enterprise environments is complex. Karmada, a multi-cluster orchestration system, provides a unified  control plane for Kubernetes clusters. It enables seamless workload deployment, scaling, and management across on-premises and multi-cloud  setups, addressing operational challenges, reducing vendor lock-in, and enhancing disaster recovery and infrastructure efficiency.","integrations":"Volcano, Kubeflow, Kyverno, Pytorch, TensorFlow, Flink, Spark, OpenKruise, Grafana, Prometheus, Argo, Flux, Istio, Filebeat, Submariner, Velero, etc.","personas":["Cloud Architects","Platform Engineers","DevOps Engineer","DevOps practitioners","DevSecOps practitioners"],"release_rate":"Every 3 months","tags":["multi-cloud","hybrid cloud"],"use_case":"Karmada (Kubernetes Armada) is a Kubernetes management system that enables you to run your cloud-native applications across multiple Kubernetes clusters and clouds, with no changes to your applications. By speaking Kubernetes-native APIs and providing advanced scheduling  capabilities, Karmada enables truly open, multi-cloud Kubernetes. Karmada aims to provide turnkey automation for multi-cluster application management in multi-cloud and hybrid cloud scenarios, with key  features such as centralized multi-cloud management, high availability, failure recovery, and traffic scheduling."},"twitter_url":"https://x.com/karmada_io"}]